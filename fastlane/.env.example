# Copy to fastlane/.env (gitignored) and fill ASC_ISSUER_ID.
# fastlane auto-loads fastlane/.env at startup.
#
# Get the Issuer ID from App Store Connect → Users and Access → Integrations →
# App Store Connect API → it's the UUID shown at the top of the keys list.

ASC_KEY_ID=BB23N5JB9M
ASC_ISSUER_ID=REPLACE_WITH_ISSUER_ID
ASC_KEY_FILEPATH=~/.appstoreconnect/private_keys/AuthKey_BB23N5JB9M.p8
ASC_APP_ID=6755371742
ASC_BUNDLE_ID=anorha.alpha
ASC_APPLE_ID=danielosagie0@gmail.com
ASC_LOCALE=en-US
