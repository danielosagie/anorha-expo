# EAS build-archive ignore list.
# When this file exists, EAS uses it INSTEAD of .gitignore to decide what to
# strip from the build upload. It mirrors .gitignore so every secret/credential
# and all junk stays excluded — EXCEPT .env.local, which is re-included at the
# bottom so Metro can inline EXPO_PUBLIC_* vars (Clerk key, API URLs, etc.) at
# build time. .env.local remains gitignored, so nothing is committed.

# ───────────────────────────── Dependencies ─────────────────────────────
node_modules/

# ───────────────────────────── Expo / build ─────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts
*.tsbuildinfo

# Native projects (managed/prebuild — regenerated, not source of truth)
/ios
/android

# Metro
.metro-health-check*

# ──────────────────── Secrets — keep stripped from the archive ───────────
.env
.env.*
*.local
!.env.example
*.pem
*.p12
*.p8
*.key
*.jks
*.keystore
*.mobileprovision
*-service-account*.json
*serviceAccount*.json
anorha-*.json
google-services.json
GoogleService-Info.plist

# ──────────────────── Build artifacts (use EAS, not git) ─────────────────
*.ipa
*.aab
*.apk
*.app

# ───────────────────────────── Logs & dumps ─────────────────────────────
*.log
logs/
logs*.json
ts_errors.txt
diff.txt

# ───────────────────────────── OS / editor ──────────────────────────────
.DS_Store
**/.DS_Store
*.orig.*
npm-debug.*
yarn-debug.*
yarn-error.*

# ─────────── Re-include the runtime env so the build is configured ───────
# Must come AFTER the .env/.local exclusions above (last match wins).
# Holds EXPO_PUBLIC_* values (already pk_live / prod hosts). Local builds keep
# this file on your machine; if you ever switch to cloud `eas build`, move these
# to EAS environment variables instead so secrets don't upload to EAS servers.
!.env.local
