{
  "expo": {
    "name": "Anorha",
    "slug": "sssync",
    "owner": "anorha",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0E8F7F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "anorha.alpha",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "anorha.alpha"
    },
    "web": {},
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow anorha to access your camera",
          "microphonePermission": "Allow anorha to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      [
        "react-native-vision-camera"
      ],
      [
        "expo-font"
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#200030",
          "image": "./src/assets/anorha_logo.png",
          "resizeMode": "contain",
          "imageWidth": 200,
          "dark": {
            "image": "./src/assets/anorha_logo.png"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps._some_id_here_"
        }
      ],
      [
        "react-native-vision-camera",
      {
        "enableCodeScanner": true
      }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b69b9883-c163-494e-aa0a-54b0e70feb3b"
      }
    },
    "scheme": "anorhaapp"
  }
}
