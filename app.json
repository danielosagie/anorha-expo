{
  "expo": {
    "name": "Anorha",
    "slug": "sssync",
    "owner": "anorha",
    "version": "1.0.2",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./src/assets/1024_anorha.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFF9EB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "anorha.alpha",
      "buildNumber": "18",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Anorha may access your location to provide enhanced features through third-party services. Location access is optional and can be disabled in your device settings.",
        "NSFaceIDUsageDescription": "Allow Anorha to use Face ID for quick and secure access to your account."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "anorha.alpha",
      "versionCode": 1
    },
    "web": {},
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow anorha to access your camera",
          "microphonePermission": "Allow anorha to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-font"
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF9EB",
          "image": "./src/assets/anorha_logo.png",
          "resizeMode": "contain",
          "imageWidth": 200,
          "dark": {
            "image": "./src/assets/anorha_logo.png"
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "enableCodeScanner": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Anorha to use Face ID for quick and secure access to your account."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b69b9883-c163-494e-aa0a-54b0e70feb3b"
      }
    },
    "scheme": "anorhaapp"
  }
}